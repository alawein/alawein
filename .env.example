# GitHub dashboard generator token (preferred)
DASHBOARD_GITHUB_TOKEN=ghp_your_token_here

# Backward-compatible fallback token names
# GITHUB_DASHBOARD_TOKEN=ghp_your_token_here
# GITHUB_TOKEN=ghp_your_token_here

# Notion sync (scripts/sync-to-notion.mjs) — same mapping as .github/workflows/notion-sync.yml
NOTION_TOKEN=
NOTION_DB_ID=
# Optional overrides (defaults match the workflow):
# NOTION_DOMAIN_PROPERTY=Domain
# NOTION_CATEGORY_PROPERTY=Status
# NOTION_TAGS_PROPERTY=Stack
# NOTION_NAME_PROPERTY=Project Name
# NOTION_DESCRIPTION_PROPERTY=One-Liner
# NOTION_REPO_PROPERTY=Repo
# NOTION_AUTO_CREATE_OPTIONS=1
#
# Local one-shot (validate + sync + verify):
#   pwsh -File scripts/run-notion-local.ps1
