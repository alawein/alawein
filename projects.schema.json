{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./projects.schema.json",
  "title": "Alawein projects manifest",
  "description": "Canonical portfolio and package list for the alawein organization",
  "type": "object",
  "required": ["featured", "research", "packages"],
  "$defs": {
    "projectEntry": {
      "type": "object",
      "required": ["name", "slug", "repo", "description", "tags", "category"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "legacy_slugs": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string", "format": "uri" },
        "repo": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": {
          "type": "string",
          "enum": ["active", "maintained", "planned", "archived", "frozen"]
        },
        "portfolio_domain": {
          "type": "string",
          "description": "Notion Domain select",
          "enum": ["Work", "Personal", "scientific-computing"]
        },
        "bucket": {
          "type": "string",
          "enum": ["products", "personal", "family", "research", "tools", "ventures", "jobs-projects", "archive"],
          "description": "Top-level alawein/ bucket. Set for alawein-org repos; omitted for cross-org entries."
        },
        "status": { "type": "string" },
        "visibility": { "type": "string", "enum": ["public", "private"] },
        "vercel": { "$ref": "#/$defs/vercelBlock" }
      }
    },
    "vercelBlock": {
      "type": "object",
      "description": "Vercel deployment state. Sourced in catalog/repos.json; team_slug and project_slug are declarative, the remaining four fields are rewritten by scripts/vercel/sync-vercel.py.",
      "required": ["team_slug", "project_slug", "production_url", "custom_domain", "state", "last_synced_at"],
      "additionalProperties": false,
      "properties": {
        "team_slug": { "type": "string", "minLength": 1 },
        "project_slug": { "type": "string", "minLength": 1 },
        "production_url": { "type": ["string", "null"] },
        "custom_domain": { "type": ["string", "null"] },
        "state": {
          "type": "string",
          "enum": ["production", "preview-only", "stale", "missing"]
        },
        "last_synced_at": { "type": "string" }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "lastUpdated": { "type": "string", "format": "date" },
    "featured": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectEntry" }
    },
    "notion_sync": {
      "type": "array",
      "description": "Extra rows pushed only to Notion (not README); same shape as featured",
      "items": { "$ref": "#/$defs/projectEntry" }
    },
    "research": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "slug", "repo", "domain"],
        "properties": {
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "legacy_slugs": { "type": "array", "items": { "type": "string" } },
          "repo": { "type": "string" },
          "domain": { "type": "string" },
          "description": { "type": "string" },
          "bucket": {
            "type": "string",
            "enum": ["products", "personal", "family", "research", "tools", "ventures", "jobs-projects", "archive"],
            "description": "Top-level alawein/ bucket. Set for alawein-org repos; omitted for cross-org entries."
          },
          "status": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "private"] },
          "vercel": { "$ref": "#/$defs/vercelBlock" }
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "registry", "url", "description"],
        "properties": {
          "name": { "type": "string" },
          "registry": { "type": "string", "enum": ["npm", "pypi"] },
          "url": { "type": "string", "format": "uri" },
          "description": { "type": "string" }
        }
      }
    },
    "infrastructure": {
      "type": "array",
      "description": "Workspace tooling repos (folder names may differ from GitHub slug)",
      "items": {
        "type": "object",
        "required": ["name", "slug", "repo", "purpose"],
        "properties": {
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "repo": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "purpose": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "visibility": { "type": "string", "enum": ["public", "private"] },
          "note": { "type": "string" },
          "bucket": {
            "type": "string",
            "enum": ["products", "personal", "family", "research", "tools", "ventures", "jobs-projects", "archive"],
            "description": "Top-level alawein/ bucket. Set for alawein-org repos; omitted for cross-org entries."
          },
          "vercel": { "$ref": "#/$defs/vercelBlock" }
        }
      }
    }
  }
}
