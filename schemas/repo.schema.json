{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./repo.schema.json",
  "title": "Repository catalog manifest",
  "type": "object",
  "required": ["schemaVersion", "lastVerified", "repos"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "lastVerified": { "type": "string", "format": "date" },
    "repos": {
      "type": "array",
      "items": { "$ref": "#/$defs/repo" }
    }
  },
  "$defs": {
    "repo": {
      "type": "object",
      "required": [
        "name",
        "slug",
        "repo",
        "local_path",
        "type",
        "surface",
        "stack",
        "domain",
        "lifecycle",
        "visibility",
        "owner",
        "maintainer",
        "docs_owner",
        "theme_family",
        "brand_family",
        "status",
        "canonical_description",
        "github_topics",
        "github_custom_properties",
        "depends_on",
        "provides",
        "version_source",
        "last_verified"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "legacy_slugs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "repo": { "type": "string", "minLength": 3 },
        "local_path": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["product", "tooling", "infra", "research", "archive", "governance"]
        },
        "surface": {
          "type": "string",
          "enum": ["web", "cli", "library", "service", "monorepo", "docs-hub", "dataset", "workflow", "asset-pack"]
        },
        "stack": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "domain": { "type": "string", "minLength": 1 },
        "audience": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "lifecycle": {
          "type": "string",
          "enum": ["planned", "active", "maintained", "archived"]
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "internal"]
        },
        "owner": { "type": "string", "minLength": 1 },
        "maintainer": { "type": "string", "minLength": 1 },
        "docs_owner": { "type": "string", "minLength": 1 },
        "theme_family": { "type": "string", "minLength": 1 },
        "brand_family": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "homepage": { "type": "string" },
        "canonical_description": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "github_topics": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "github_custom_properties": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "repo_settings": {
          "type": "object",
          "required": [
            "default_workflow_permissions",
            "can_approve_pull_request_reviews",
            "release_pr_automation"
          ],
          "properties": {
            "default_workflow_permissions": {
              "type": "string",
              "enum": ["read", "write"]
            },
            "can_approve_pull_request_reviews": { "type": "boolean" },
            "release_pr_automation": {
              "type": "string",
              "enum": ["none", "changesets"]
            }
          },
          "additionalProperties": false
        },
        "vercel": {
          "type": "object",
          "required": [
            "project_name",
            "project_link_source",
            "framework",
            "root_directory",
            "install_command",
            "build_command",
            "output_directory",
            "node_version"
          ],
          "properties": {
            "project_name": { "type": "string", "minLength": 1 },
            "project_link_source": { "type": "string", "minLength": 1 },
            "framework": { "type": "string", "minLength": 1 },
            "root_directory": { "type": "string" },
            "install_command": { "type": "string", "minLength": 1 },
            "build_command": { "type": "string", "minLength": 1 },
            "output_directory": { "type": "string", "minLength": 1 },
            "node_version": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "provides": {
          "type": "array",
          "items": { "type": "string" }
        },
        "version_source": { "type": "string", "minLength": 1 },
        "last_verified": { "type": "string", "format": "date" },
        "catalog_groups": {
          "type": "array",
          "items": { "type": "string" }
        },
        "portfolio_domain": { "type": "string" },
        "research_domain": { "type": "string" }
      }
    }
  }
}
