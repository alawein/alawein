{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./template.schema.json",
  "title": "Template manifest",
  "type": "object",
  "required": ["schemaVersion", "templates"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "templates": {
      "type": "array",
      "items": { "$ref": "#/$defs/template" }
    }
  },
  "$defs": {
    "template": {
      "type": "object",
      "required": [
        "slug",
        "name",
        "path",
        "type",
        "owner",
        "source_repo",
        "consumers",
        "version_source",
        "description"
      ],
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "type": { "type": "string" },
        "owner": { "type": "string" },
        "source_repo": { "type": "string" },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "automation": { "type": "string" },
        "version_source": { "type": "string" },
        "description": { "type": "string" },
        "required_sections": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
