{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./workflow.schema.json",
  "title": "Workflow manifest",
  "type": "object",
  "required": ["schemaVersion", "workflows"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "workflows": {
      "type": "array",
      "items": { "$ref": "#/$defs/workflow" }
    }
  },
  "$defs": {
    "workflow": {
      "type": "object",
      "required": [
        "slug",
        "name",
        "path",
        "type",
        "owner",
        "source_repo",
        "consumers",
        "version_source",
        "description"
      ],
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "type": { "type": "string" },
        "owner": { "type": "string" },
        "source_repo": { "type": "string" },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "schedule": { "type": "string" },
        "version_source": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
